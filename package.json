{
  "name": "omnisuite-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "app": "node launcher.js",
    "build:exe": "npx pkg@latest launcher.js --targets node18-win-x64 -o OmniSuite.exe",
    "dev": "concurrently \"node scripts/start-backend.js\" \"npm run dev:engine\" \"npm run dev:next-ipv4\"",
    "dev:next-ipv4": "node --dns-result-order=ipv4first node_modules/next/dist/bin/next dev",
    "dev:all": "npm run dev",
    "dev:next": "next dev",
    "dev:python": "python scripts/interpreter_service.py",
    "dev:engine": "python -m uvicorn python_engine.main:app --host 127.0.0.1 --port 8082 --reload",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "depcruise": "depcruise src --config .dependency-cruiser.js",
    "depcruise:graph": "depcruise src --include-only \"^src\" --output-type dot | dot -Tsvg > dependency-graph.svg"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/groq": "^3.0.31",
    "@ai-sdk/openai": "^3.0.49",
    "@tailwindcss/typography": "^0.5.19",
    "ai": "^6.0.142",
    "archiver": "^7.0.1",
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "html-to-docx": "^1.8.0",
    "lucide-react": "^1.7.0",
    "mammoth": "^1.12.0",
    "marked": "^17.0.5",
    "next": "16.2.2",
    "next-auth": "^4.24.13",
    "p-limit": "^7.3.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.59.1",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.4",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^7.0.0",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
