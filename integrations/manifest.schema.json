{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OmniSuite Integrations Manifest",
  "type": "object",
  "required": ["version", "integrations"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "integrations": {
      "type": "array",
      "items": { "$ref": "#/definitions/integration" },
      "minItems": 1
    }
  },
  "definitions": {
    "integration": {
      "type": "object",
      "required": ["id", "name", "path", "kind", "integrationStrategy", "features", "setupHint"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "pattern": "^integrations/" },
        "kind": {
          "enum": ["python-cli", "python-script", "node-app", "docker-app"]
        },
        "integrationStrategy": {
          "enum": ["ai-support-runner", "external-app"]
        },
        "features": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "setupHint": { "type": "string", "minLength": 1 },
        "slashCommand": { "type": "string", "pattern": "^/" },
        "probe": {
          "type": "object",
          "required": ["bin", "args"],
          "properties": {
            "bin": { "type": "string" },
            "args": { "type": "array", "items": { "type": "string" } }
          }
        },
        "runner": {
          "type": "object",
          "required": ["script"],
          "properties": {
            "script": { "type": "string" },
            "maxTaskLen": { "type": "integer", "minimum": 256 }
          }
        },
        "submodule": {
          "type": "object",
          "required": ["url"],
          "properties": {
            "url": { "type": "string", "format": "uri" },
            "shallowFallback": { "type": "boolean" }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "integrationStrategy": { "const": "ai-support-runner" } } },
          "then": { "required": ["runner"] }
        }
      ]
    }
  }
}
