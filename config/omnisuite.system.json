{
  "version": 1,
  "app": {
    "name": "OmniSuite AI",
    "mode": "go",
    "dashboardUrl": "http://localhost:3000"
  },
  "bigUpdate": {
    "name": "System Spine",
    "version": "2026.06.19",
    "goal": "Mot khung xuong chung de bam-la-chay, tu kiem tra, tu sua va giam lenh nguoi dung phai go.",
    "principles": [
      "one_click_start",
      "one_click_repair",
      "local_runtime_only",
      "contract_driven_services",
      "doctor_before_start",
      "single_dependency_signature"
    ],
    "entrypoints": {
      "windowsStart": "01_START_OMNISUITE.bat",
      "windowsStop": "02_STOP_OMNISUITE.bat",
      "windowsUninstall": "03_UNINSTALL_OMNISUITE.bat"
    }
  },
  "entrypoints": {
    "windowsStart": "01_START_OMNISUITE.bat",
    "windowsStop": "02_STOP_OMNISUITE.bat",
    "windowsUninstall": "03_UNINSTALL_OMNISUITE.bat"
  },
  "envDefaults": {
    "NEXTAUTH_URL": "http://localhost:3000",
    "PYTHON_ENGINE_URL": "http://127.0.0.1:8082",
    "OMNISUITE_STRICT_SECURITY": "1",
    "OMNISUITE_LOCALHOST_ONLY": "1",
    "DATABASE_URL": "skip"
  },
  "services": [
    {
      "id": "python-backend",
      "label": "Python Backend",
      "port": 8081,
      "required": false,
      "command": "node",
      "args": ["scripts/start-backend.js"],
      "healthUrl": "http://127.0.0.1:8081/health",
      "group": "backend"
    },
    {
      "id": "image-pipeline",
      "label": "Image Pipeline / CLIP",
      "port": 8000,
      "required": false,
      "managedBy": "python-backend",
      "healthUrl": "http://127.0.0.1:8000/api/v1/health",
      "group": "media"
    },
    {
      "id": "python-engine",
      "label": "Python Engine",
      "port": 8082,
      "required": true,
      "command": "python",
      "args": ["-m", "uvicorn", "python_engine.main:app", "--host", "127.0.0.1", "--port", "8082", "--reload"],
      "healthUrl": "http://127.0.0.1:8082/",
      "group": "backend"
    },
    {
      "id": "next-frontend",
      "label": "Next.js Frontend",
      "port": 3000,
      "required": true,
      "command": "node",
      "args": ["scripts/run-next-dev.js"],
      "healthUrl": "http://127.0.0.1:3000/",
      "group": "frontend"
    }
  ],
  "setup": {
    "stateFile": ".omnisuite/quick-start-state.json",
    "signatureFiles": [
      "package-lock.json",
      "package.json",
      "requirements.txt",
      "python_engine/requirements.txt",
      "services/clip_service/requirements.txt",
      "config/omnisuite.system.json"
    ],
    "requiredNodeModules": ["next", "playwright"],
    "requiredPythonModules": [
      "fastapi",
      "uvicorn",
      "flask",
      "httpx",
      "bs4",
      "playwright",
      "pytrends",
      "pandas",
      "numpy",
      "sklearn"
    ]
  },
  "commands": {
    "start": "01_START_OMNISUITE.bat",
    "repair": "01_START_OMNISUITE.bat",
    "bigUpdate": "01_START_OMNISUITE.bat",
    "stop": "02_STOP_OMNISUITE.bat",
    "uninstall": "03_UNINSTALL_OMNISUITE.bat"
  }
}
