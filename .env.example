# Để trống hoặc bỏ INTERNAL_TOKEN = runner (/run, /run-browser) không cần header / không cần nhập trong Cài đặt.
INTERNAL_TOKEN=
NEXTAUTH_SECRET=your_nextauth_secret_here
SERPAPI_KEY=
TAVILY_API_KEY=
OPENAI_API_KEY=
# Gemini / Google AI Studio (Next.js + Python engine đọc các tên sau — chỉ cần một dòng)
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# Claude / Anthropic — dùng một trong hai tên (đều được map vào claude_api_key)
CLAUDE_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
# Ollama LOCAL: cài từ https://ollama.com → chạy `ollama serve` + `ollama pull llama3.2`.
# Để trống cả hai dòng dưới nếu dùng máy local mặc định http://127.0.0.1:11434
# (Next.js + Python engine vẫn tự gọi localhost khi UI không nhập URL).
# Ollama REMOTE (Colab / server + Cloudflare/ngrok tunnel) — dán ORIGIN không có /v1:
# OLLAMA_BASE_URL=https://abc123.trycloudflare.com
# OLLAMA_API_KEY=optional_bearer_neu_tunnel_yeu_cau_auth
OLLAMA_BASE_URL=
OLLAMA_API_KEY=
# --- TUỲ CHỌN: KHÔNG cần đặt nếu hài lòng với default. ---
# Mặc định trong code đã là: SEQUENTIAL 1 task, keep_alive=30s, idle 2 phút auto-unload.
# Chỉ đặt khi muốn khác default. Để trống / bỏ dòng = dùng default.
# OLLAMA_MAX_CONCURRENT=1            # 1 = sequential, làm xong task này rồi mới đến task khác.
# OLLAMA_TIMEOUT_MS=180000           # Timeout fetch Ollama phía Next.js (ms).
# OLLAMA_HTTP_TIMEOUT_SEC=180        # Timeout HTTP Python engine → Ollama (giây).
# OLLAMA_KEEP_ALIVE=30s              # "0" = unload ngay; "5m" = giữ lâu.
# OLLAMA_IDLE_UNLOAD_MS=120000       # 0 = tắt watcher; mặc định 2 phút idle → unload.
# OLLAMA_NUM_CTX=4096                # Cap context window; 0 = tôn trọng Modelfile (có thể đòi >10 GiB cho model 3B).
PYTHON_ENGINE_URL=http://127.0.0.1:8082

# AI Hỗ trợ Runner — bật để cho phép slash /run (OpenManus) và /run-browser (browser-use).
# Mặc định tắt vì runner sẽ spawn Python + có thể thực thi code / mở browser; chỉ bật trong môi trường tin cậy.
# Khi bật: nên dùng venv riêng (.venv-runners) để tránh xung đột với FastAPI global:
#   PowerShell (repo root):  .\scripts\setup-runners-venv.ps1
#   bash (repo root):        bash scripts/setup-runners-venv.sh
# Sau đó trỏ PYTHON_BIN vào Python trong .venv-runners (không dùng Python global).
AI_SUPPORT_RUNNER_ENABLED=false
# Tuỳ chọn khóa runner — chỉ khi đặt giá trị thật; không trùng INTERNAL_TOKEN / không ảnh hưởng biến Windows cho chỗ khác.
# AI_SUPPORT_RUNNER_SECRET=
# Đường dẫn Python cho runner (Windows ví dụ):
# PYTHON_BIN=.venv-runners\Scripts\python.exe
# Linux/macOS ví dụ:
# PYTHON_BIN=.venv-runners/bin/python
#
# Neu duong dan repo co Unicode va pip spam loi encoding trong PowerShell: chay truoc
# chcp 65001 hoac bat UTF-8 trong Terminal Windows (scripts/setup-runners-venv.ps1 da set PYTHONUTF8).
